-- ─── No Leaves (tree canopy only — SpawnerZones.Foliage folder) ──────────────
-- ONLY hides parts inside workspace.SpawnerZones.Foliage.
-- Never touches players, weapons, clothes, or any regular world geometry.
removeLeafMeshes = function()
    local fol = workspace:FindFirstChild("SpawnerZones")
              and workspace.SpawnerZones:FindFirstChild("Foliage")
    if not fol then return end
    for _, v in pairs(fol:GetDescendants()) do
        -- Only hide if it has a SurfaceAppearance (leaf mesh indicator)
        -- AND is not a BasePart that could be a trunk (trunks tend to not have SurfaceAppearance)
        if v:IsA("BasePart") or v:IsA("MeshPart") then
            if v:FindFirstChildOfClass("SurfaceAppearance") then
                pcall(function()
                    v.Transparency = 1
                    v.CanCollide   = false
                end)
            end
        end
    end
end

BrzS.applyNoLeaves = function(enabled)
    if BrzS._leavesConn    then pcall(function() if task.cancel then task.cancel(BrzS._leavesConn) end end); BrzS._leavesConn    = nil end
    if BrzS._leavesAddConn then BrzS._leavesAddConn:Disconnect(); BrzS._leavesAddConn = nil end

    if enabled then
        removeLeafMeshes()

        -- re-apply every 10s to catch foliage that streams in later
        local function _loopLeaves()
            while BrzS.noLeaves do
                task.wait(10)
                if BrzS.noLeaves then removeLeafMeshes() end
            end
        end
        task.spawn(_loopLeaves)

        -- Only watch NEW objects inside the Foliage folder specifically
        local fol = workspace:FindFirstChild("SpawnerZones")
                  and workspace.SpawnerZones:FindFirstChild("Foliage")
        if fol then
            BrzS._leavesAddConn = fol.DescendantAdded:Connect(function(obj)
                if not BrzS.noLeaves then return end
                if (obj:IsA("BasePart") or obj:IsA("MeshPart"))
                   and obj:FindFirstChildOfClass("SurfaceAppearance") then
                    task.defer(function()
                        pcall(function() obj.Transparency = 1; obj.CanCollide = false end)
                    end)
                end
            end)
        end
    else
        -- restore only the Foliage folder parts
        local fol = workspace:FindFirstChild("SpawnerZones")
                  and workspace.SpawnerZones:FindFirstChild("Foliage")
        if fol then
            for _, v in pairs(fol:GetDescendants()) do
                if (v:IsA("BasePart") or v:IsA("MeshPart"))
                   and v:FindFirstChildOfClass("SurfaceAppearance") then
                    pcall(function() v.Transparency = 0; v.CanCollide = true end)
                end
            end
        end
    end
end

