-- Keybind toggle to show/hide target info on demand.
-- Key is required by the library — RightAlt is a low-conflict default.
local _tiBindTog = TargetBox:Toggle({Title = "bind toggle", Flag = "targetinfo_bind_tog", Default = false})
_tiBindTog:Keybind({
    Title     = "bind",
    Flag      = "targetinfo_bind",
    Key       = Enum.KeyCode.RightAlt,   -- ← Key is required, prevents the EnumType nil crash
    StateType = "Toggle",
    Callback  = function()
        -- toggling visibility is handled in the render loop below
    end
})

do
    local _UIS     = game:GetService("UserInputService")
    local _Players = game:GetService("Players")
    local _LP      = _Players.LocalPlayer
    local _showing = true

    local _tiDrawings = {}
    for i = 1, 6 do
        local d = Drawing.new("Text")
        d.Visible = false; d.Outline = true; d.Font = 3
        d.Color = Color3.fromRGB(255, 155, 205)
        d.OutlineColor = Color3.new(0, 0, 0)
        d.Center = true
        _tiDrawings[i] = d
    end

    local function _tiHideAll()
        for _, d in ipairs(_tiDrawings) do d.Visible = false end
    end

    local function _tiVisible(head)
        local origin = cam.CFrame.Position
        local dir    = head.Position - origin
        local rp     = RaycastParams.new()
        rp.FilterDescendantsInstances = {_LP.Character}
        rp.FilterType = Enum.RaycastFilterType.Blacklist
        local result = workspace:Raycast(origin, dir, rp)
        return result and result.Instance:IsDescendantOf(head.Parent)
    end

    local function _tiClosest()
        local mousePos = _UIS:GetMouseLocation()
        local closest, dist = nil, math.huge
        for _, plr in ipairs(_Players:GetPlayers()) do
            if plr ~= _LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local pos, onScreen = cam:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if d < dist then dist = d; closest = plr end
                end
            end
        end
        return closest
    end

    -- Toggle _showing when the keybind fires
    RunService.Heartbeat:Connect(function()
        if not Library.Flags["targetinfo_enabled"] then return end
        local bindState = Library.Flags["targetinfo_bind"]
        -- bindState flips each time the key is pressed (Toggle mode)
        -- we use it directly as the visible flag
        _showing = (bindState == nil) or bindState
    end)

    task.spawn(function()
        while true do
            task.wait(0.025)
            if not Library.Flags["targetinfo_enabled"] or not _showing then
                _tiHideAll(); continue
            end
            local target = _tiClosest()
            if not target or not target.Character then _tiHideAll(); continue end

            local head = target.Character:FindFirstChild("Head")
            local hum  = target.Character:FindFirstChildOfClass("Humanoid")
            local hrp  = target.Character:FindFirstChild("HumanoidRootPart")
            if not head or not hum or not hrp then _tiHideAll(); continue end

            local size    = Library.Flags["targetinfo_size"]    or 15
            local yOffset = Library.Flags["targetinfo_yoffset"] or 0
            local index   = 1

            local function push(text)
                local d = _tiDrawings[index]
                d.Size     = size
                d.Text     = tostring(text)
                d.Position = Vector2.new(
                    cam.ViewportSize.X / 2,
                    cam.ViewportSize.Y / 2 + yOffset + (index - 1) * (size + 2)
                )
                d.Color   = Color3.fromRGB(255, 155, 205)
                d.Visible = true
                index     = index + 1
            end

            for i = index, #_tiDrawings do _tiDrawings[i].Visible = false end

            if Library.Flags["targetinfo_name"]     then push(string.lower(target.Name)) end
            if Library.Flags["targetinfo_visible"]  then push(_tiVisible(head) and "visible" or "hidden") end
            if Library.Flags["targetinfo_moving"]   then
                local vel = hrp.Velocity
                push(Vector3.new(vel.X,0,vel.Z).Magnitude > 1 and "moving" or "still")
            end
            if Library.Flags["targetinfo_hp"]       then
                push(string.format("%d%%", math.clamp(hum.Health/hum.MaxHealth*100, 0, 100)))
            end
            if Library.Flags["targetinfo_holding"]  then
                local holding = "none"
                local h = target.Character:FindFirstChild("Holding", true)
                if h and h:IsA("ObjectValue") and h.Value then holding = string.lower(h.Value.Name) end
                push(holding)
            end
            if Library.Flags["targetinfo_distance"] then
                local studs = (cam.CFrame.Position - hrp.Position).Magnitude
                push(math.floor(studs * 0.28) .. "m")
            end

            for i = index, #_tiDrawings do _tiDrawings[i].Visible = false end
        end
    end)
end

local FreeCamSection = VisTab:Section("free cam", "Left")
do
    local _fcEnabled = false
    local _fcCam = nil
    local _fcConn = nil
    local _fcSpeed = 20
    local _fcSensLabel = FreeCamSection:Label("speed: 20")

    FreeCamSection:Toggle({Title = "enable free cam", Flag = "FreeCam", Default = false, Callback = function(s)
        _fcEnabled = s
        if s then
            _fcCam = {mode = cam.CameraType, subject = cam.CameraSubject, cf = cam.CFrame}
            cam.CameraType = Enum.CameraType.Scriptable
            cam.CameraSubject = nil
            local UIS2 = game:GetService("UserInputService")
            local RS2  = game:GetService("RunService")
            local pitch, yaw = 0, 0
            local lastMouse = UIS2:GetMouseLocation()
            local sens = 0.003
            _fcConn = RS2.RenderStepped:Connect(function(dt)
                if not _fcEnabled then
                    if _fcConn then _fcConn:Disconnect(); _fcConn = nil end; return
                end
                local m = UIS2:GetMouseLocation()
                local dx = m.X - lastMouse.X; local dy = m.Y - lastMouse.Y
                lastMouse = m
                yaw   = yaw - dx * sens
                pitch = math.clamp(pitch - dy * sens, -math.pi/2+0.01, math.pi/2-0.01)
                local rot = CFrame.Angles(0,yaw,0) * CFrame.Angles(pitch,0,0)
                local move = Vector3.new()
                local spd = _fcSpeed * dt
                if UIS2:IsKeyDown(Enum.KeyCode.W) then move = move + rot.LookVector end
                if UIS2:IsKeyDown(Enum.KeyCode.S) then move = move - rot.LookVector end
                if UIS2:IsKeyDown(Enum.KeyCode.A) then move = move - rot.RightVector end
                if UIS2:IsKeyDown(Enum.KeyCode.D) then move = move + rot.RightVector end
                if UIS2:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.new(0,1,0) end
                if UIS2:IsKeyDown(Enum.KeyCode.Q) then move = move - Vector3.new(0,1,0) end
                cam.CFrame = CFrame.new(cam.CFrame.Position + move*spd) * rot
            end)
        else
            if _fcConn then _fcConn:Disconnect(); _fcConn = nil end
            if _fcCam then
                cam.CameraType = _fcCam.mode or Enum.CameraType.Custom
                cam.CameraSubject = game:GetService("Players").LocalPlayer.Character
                    and game:GetService("Players").LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    or _fcCam.subject
            end
        end
    end})
    FreeCamSection:Slider({Title = "speed", Flag = "FreeCamSpeed", Symbol = "", Default = 20, Min = 5, Max = 150, Decimals = 0, Callback = function(v)
        _fcSpeed = v; _fcSensLabel:Set("speed: "..v)
    end})
end

