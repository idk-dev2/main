applyExecutorGating = function()
    if _G.EH_PAID_EXECUTOR then return end
    -- bright amber so it's legible on any dark background
    local LOCKED_COLOR  = Color3.fromRGB(252, 180, 30)
    local LOCK_SUFFIX   = " ★ paid"

    for _, flag in ipairs(PAID_ONLY_FLAGS) do
        local toggle = Library._toggles and Library._toggles[flag]
        if toggle then
            if toggle.Toggled then toggle:Set(false) end

            if toggle._titleDrawing then
                local cur = toggle._titleDrawing.Text
                -- strip any old suffix before appending, avoid doubling up
                cur = cur:gsub(" %★ paid$", ""):gsub(" %[paid%]$", "")
                toggle._titleDrawing.Text  = cur .. LOCK_SUFFIX
                toggle._titleDrawing.Color = LOCKED_COLOR
            end
            if toggle._outlineDrawing then
                toggle._outlineDrawing.Color = LOCKED_COLOR
            end

            if Library._clickables and toggle._clickEntry then
                for i = #Library._clickables, 1, -1 do
                    if Library._clickables[i] == toggle._clickEntry then
                        table.remove(Library._clickables, i)
                        break
                    end
                end
            end
        end
        Library.Flags[flag] = false
    end
end

task.defer(applyExecutorGating)

