local _WANTED_ITEMS = {
    Altyn=true, FastVisor=true, HSPV=true, JPC=true,
    QuadNVG=true, IOTV4=true, TitanShield=true,
    AsVal=true, FAL=true, M4=true, PKM=true,
    R700=true, TFZ98S=true,
    FlareGun=true, SPSh44=true, Gold50g=true,
    Mag556Rnd100=true, Repair=true, SOCOM556=true,
}
local _wantedAlerted = {}

function _runWantedScan()
    if not BrzS.wantedItemScanner then return end
    local rsPlayers = ReplicatedStorage:FindFirstChild("Players")
    if not rsPlayers then return end
    -- reset alert cache each cycle so it notifies every scan
    _wantedAlerted = {}
    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr == player then continue end
        local pFolder = rsPlayers:FindFirstChild(plr.Name)
        if not pFolder then continue end
        local inv = pFolder:FindFirstChild("Inventory")
        if not inv then continue end
        local found = {}
        local function scanDeep(container, depth)
            if not container or depth > 4 then return end
            for _, child in ipairs(container:GetChildren()) do
                if _WANTED_ITEMS[child.Name] then found[child.Name] = true end
                if child:IsA("Folder") or child:IsA("Model") then
                    scanDeep(child, depth + 1)
                end
            end
        end
        scanDeep(inv, 0)
        if next(found) then
            local items = {}
            for name in pairs(found) do items[#items+1] = name end
            EH_Notify("[" .. plr.Name .. "] has wanted items! " .. table.concat(items, ", "), 10)
        end
    end
end

