-- ─── Mod Detector + Cheat Detector ──────────────────────────────────────────
-- Adapted from reference: checks PremiumLevel >= 4 (moderators) and invisible body parts.
-- CheatDetector: checks KDR + ReportList HSR flags.
local function _runCheatDetector(p)
    if p == player then return end
    if not BrzS.cheatDetector then return end
    if BrzS._cheaterList[p.Name] then return end
    pcall(function()
        local rsPlayer = game.ReplicatedStorage.Players:FindFirstChild(p.Name)
        if not rsPlayer then return end
        local status = rsPlayer:FindFirstChild("Status")
        local journey = status and status:FindFirstChild("Journey")
        local wipe = journey and journey:FindFirstChild("WipeStatistics")
        if not wipe then return end

        local deaths = math.max(wipe:GetAttribute("Deaths") or 0, 1)
        local kills  = wipe:GetAttribute("Kills") or 0
        local kdr    = math.floor(kills / deaths * 10) / 10

        -- Live HSR from Combat attributes (same as game's own ReportInteractionManager)
        local combat    = rsPlayer.Status.GameplayVariables.Combat
        local hs        = combat:GetAttribute("Headshots") or 0
        local bs        = combat:GetAttribute("Bodyshots") or 0
        local total     = hs + bs
        local hsr       = total > 0 and math.ceil((hs / total) * 100) or 0

        -- Report count from UAC
        local uac = rsPlayer.Status:FindFirstChild("UAC")
        local rptFolder = uac and uac:FindFirstChild("Reports")
        local reportCount = 0
        if rptFolder then for _ in pairs(rptFolder:GetAttributes()) do reportCount += 1 end end

        if kills >= 15 and hsr >= 80 then
            BrzS._cheaterList[p.Name] = true
            EH_Notify("[CHEAT] " .. p.Name .. " HSR:" .. hsr .. "% KDR:" .. kdr .. " (aimbot)", 8)
        elseif kills > 0 and kdr >= 15 then
            BrzS._cheaterList[p.Name] = true
            EH_Notify("[CHEAT] " .. p.Name .. " KDR:" .. kdr .. " HSR:" .. hsr .. "%", 8)
        elseif reportCount >= 5 and hsr >= 60 then
            BrzS._cheaterList[p.Name] = true
            EH_Notify("[CHEAT] " .. p.Name .. " " .. reportCount .. " rpts HSR:" .. hsr .. "%", 8)
        end
    end)
end

local function _runModDetector()
    if not BrzS.modDetector then return end
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p == player then continue end
        _runCheatDetector(p)
        if not BrzS._modChecked[p.Name] and p.Character then
            -- Method A: PremiumLevel >= 4
            pcall(function()
                local rsP = game.ReplicatedStorage.Players:FindFirstChild(p.Name)
                local gv = rsP and rsP:FindFirstChild("Status") and rsP.Status:FindFirstChild("GameplayVariables")
                if gv and (gv:GetAttribute("PremiumLevel") or 0) >= 4 then
                    if not BrzS._modWarnings[p.Name] then BrzS._modWarnings[p.Name] = 0 end
                    BrzS._modWarnings[p.Name] = BrzS._modWarnings[p.Name] + 1
                    EH_Notify("[MOD] " .. p.Name .. " premium admin", 8)
                end
            end)
            -- Method B: invisible body parts (admin invisible hack)
            if p.Character then
                pcall(function()
                    for _, part in pairs(p.Character:GetChildren()) do
                        if (part.Name == "Head" or part.Name == "UpperTorso" or part.Name == "LowerTorso")
                           and part:IsA("BasePart") and part.Transparency >= 1 then
                            if not BrzS._modWarnings[p.Name] then BrzS._modWarnings[p.Name] = 0 end
                            BrzS._modWarnings[p.Name] = BrzS._modWarnings[p.Name] + 1
                            EH_Notify("[MOD] " .. p.Name .. " invisible parts", 8)
                            break
                        end
                    end
                end)
            end
            BrzS._modChecked[p.Name] = true
        end
    end
end

