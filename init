_frOrigReloadTimes  = {}
_frOrigReloadAttrs  = {}
_frRemovedAnims     = {}
_frEquipConn        = nil

_frApplyToTemplate = function(toolName)
    local wf = ReplicatedStorage:FindFirstChild("RangedWeapons")
    if not wf then return end
    local tpl = wf:FindFirstChild(toolName)
    if not tpl then return end

    for _, obj in ipairs(tpl:GetDescendants()) do
        if obj:IsA("Animation") and obj.Name:lower():find("reload") then
            _frRemovedAnims[#_frRemovedAnims+1] = {anim=obj, parent=obj.Parent}
            obj.Parent = nil
        end
    end

    local rt = tpl:FindFirstChild("ReloadTime")
    if rt and (rt:IsA("NumberValue") or rt:IsA("IntValue")) then
        if _frOrigReloadTimes[toolName] == nil then
            _frOrigReloadTimes[toolName] = rt.Value
        end
        rt.Value = 0.01
    end

    local rta = tpl:GetAttribute("ReloadTime")
    if rta ~= nil then
        if _frOrigReloadAttrs[toolName] == nil then
            _frOrigReloadAttrs[toolName] = rta
        end
        tpl:SetAttribute("ReloadTime", 0.01)
    end
end

_frApplyAll = function()
    local wf = ReplicatedStorage:FindFirstChild("RangedWeapons")
    if not wf then return end
    for _, tpl in ipairs(wf:GetChildren()) do
        _frApplyToTemplate(tpl.Name)
    end
end

_frRestore = function()

    for _, entry in ipairs(_frRemovedAnims) do
        pcall(function()
            if entry.anim and entry.parent then
                entry.anim.Parent = entry.parent
            end
        end)
    end
    _frRemovedAnims = {}

    local wf = ReplicatedStorage:FindFirstChild("RangedWeapons")
    if wf then
        for toolName, origVal in pairs(_frOrigReloadTimes) do
            local tpl = wf:FindFirstChild(toolName)
            if tpl then
                local rt = tpl:FindFirstChild("ReloadTime")
                if rt then rt.Value = origVal end
            end
        end
        for toolName, origAttr in pairs(_frOrigReloadAttrs) do
            local tpl = wf:FindFirstChild(toolName)
            if tpl then
                tpl:SetAttribute("ReloadTime", origAttr)
            end
        end
    end
    _frOrigReloadTimes = {}
    _frOrigReloadAttrs = {}

    if _frEquipConn then _frEquipConn:Disconnect(); _frEquipConn = nil end
end

_frEnable = function()

    task.spawn(_frApplyAll)

    local char = player.Character or player.CharacterAdded:Wait()
    _frEquipConn = char.ChildAdded:Connect(function(child)
        if not BrzS.fastReload then return end
        if child:IsA("Tool") then
            task.defer(function() _frApplyToTemplate(child.Name) end)
        end
    end)
end

