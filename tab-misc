-- ─── mine detonator setup ─────────────────────────────────────────────────────
local _MineS = {
    mineFolders = {"OutpostClaymores", "OutpostLandmines", "HeliCrashClaymores",
                   "BridgeClaymores", "HydroPlant", "PowerPlant", "Claymores", "Landmines"},
    mineNames   = {"PMN2", "MON50", "ElectricityAnomaly"},
}

local function _detonateAllMines()
    local searchRoots = {
        workspace:FindFirstChild("AiZones"),
        workspace:FindFirstChild("Zones"),
        workspace:FindFirstChild("Map"),
        workspace,
    }
    local detonated = 0
    local seen = {}
    local function _explodeMine(mine)
        if seen[mine] then return end
        seen[mine] = true
        local hrp = mine:FindFirstChild("HumanoidRootPart")
              or mine:FindFirstChild("PrimaryPart")
              or mine:FindFirstChildWhichIsA("BasePart")
        if not hrp then return end
        local pos = hrp.Position
        pcall(function()
            local exp = Instance.new("Explosion")
            exp.Position = pos; exp.BlastRadius = 8; exp.BlastPressure = 0
            exp.DestroyJointRadiusPercent = 0
            exp.ExplosionType = Enum.ExplosionType.NoCraters
            exp.Parent = workspace
        end)
        pcall(function() mine:Destroy() end)
        detonated = detonated + 1
    end
    for _, root in ipairs(searchRoots) do
        if root then
            for _, folderName in ipairs(_MineS.mineFolders) do
                local folder = root:FindFirstChild(folderName, true)
                if folder then
                    for _, mine in ipairs(folder:GetChildren()) do
                        if table.find(_MineS.mineNames, mine.Name) then _explodeMine(mine) end
                    end
                end
            end
        end
    end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if table.find(_MineS.mineNames, obj.Name) and obj:IsA("Model") then _explodeMine(obj) end
    end
    return detonated
end

-- ─── bullet tracer ────────────────────────────────────────────────────────────
getgenv().BeamEnabled      = getgenv().BeamEnabled      or false
getgenv().BeamDuration     = getgenv().BeamDuration     or 2
getgenv().BeamFadeDuration = getgenv().BeamFadeDuration or 2
getgenv().EH_TracerColor   = getgenv().EH_TracerColor   or Color3.fromRGB(255, 155, 205)

local function _createBeam(origin, targetPos)
    if not getgenv().BeamEnabled then return end
    local a0 = Instance.new("Attachment")
    local a1 = Instance.new("Attachment")
    a0.WorldPosition = origin
    a1.WorldPosition = targetPos
    local beam = Instance.new("Beam")
    beam.Attachment0 = a0
    beam.Attachment1 = a1
    beam.Width0      = 0.1
    beam.Width1      = 0.05
    beam.FaceCamera  = true
    beam.Color       = ColorSequence.new(getgenv().EH_TracerColor)
    beam.Parent      = a0
    a0.Parent        = workspace.Terrain
    a1.Parent        = workspace.Terrain
    task.spawn(function()
        local t = 0
        local dur = getgenv().BeamFadeDuration
        while t < dur do
            beam.Transparency = NumberSequence.new(t / dur)
            t = t + task.wait(0.05)
        end
        a0:Destroy()
        a1:Destroy()
    end)
end

task.spawn(function()
    local RS = game:GetService("ReplicatedStorage")
    local ok, BM = pcall(require, RS.Modules.FPS.Bullet)
    if not ok or not BM or not BM.CreateBullet then return end
    local _oldBulletTracer
    _oldBulletTracer = hookfunction(BM.CreateBullet, function(a, b, c, d, aim, e, ammo, t, recoil)
        if getgenv().BeamEnabled and aim and aim.Position then
            task.spawn(function()
                local origin = aim.Position
                pcall(function()
                    local vm = cam:FindFirstChild("ViewModel")
                    if vm then
                        local itemRoot = vm:FindFirstChild("Item") and vm.Item:FindFirstChild("ItemRoot")
                        if itemRoot then origin = itemRoot.Position end
                    end
                end)
                local targetPos = origin + cam.CFrame.LookVector * 1000
                pcall(function()
                    if instantTarget and instantTarget.Parent then
                        targetPos = instantTarget.Position
                    end
                end)
                _createBeam(origin, targetPos)
            end)
        end
        return _oldBulletTracer(a, b, c, d, aim, e, ammo, t, recoil)
    end)
end)

