local Window  = _G.EH_Window
local Library = _G.EH_Library
if not _SA then _SA = {} end
if not _AA then _AA = {} end
if not _UG then _UG = {} end

MainTab = Window:Tab("esp")

ESPCtrl = MainTab:Section("control", "Left")
local _togESPEnabled = ESPCtrl:Toggle({Title = "enabled", Flag = "ESPEnabled", Default = false})
_togESPEnabled:Keybind({Title = "esp key", Flag = "ESPKey", Key = Enum.KeyCode.Delete, StateType = "Always", Callback = function() end})
ESPCtrl:Toggle({Title = "show names", Flag = "ESPNames", Default = false})
ESPCtrl:Toggle({Title = "show distance", Flag = "ESPDist", Default = false})
ESPCtrl:Toggle({Title = "show health", Flag = "ESPHealth", Default = false})
ESPCtrl:Toggle({Title = "show weapon", Flag = "ESPWeapon", Default = false})
ESPCtrl:Toggle({Title = "npc esp", Flag = "ESPNpc", Default = false})
ESPCtrl:Toggle({Title = "team check", Flag = "ESPTeam", Default = false})
ESPCtrl:Toggle({Title = "visible check color", Flag = "ESPVisCheck", Default = false})

ESPCtrl:Toggle({Title = "show extracts", Flag = "ESPExtracts", Default = false, Callback = function(s)
    if espS then espS.showExtracts = s end
end})
ESPCtrl:Toggle({Title = "show hsr%", Flag = "ESPShowHSR", Default = false, Callback = function(s)
    if espS then espS.showHSR = s end
end})
ESPCtrl:Toggle({Title = "show reports", Flag = "ESPShowReports", Default = false, Callback = function(s)
    if espS then espS.showReports = s end
end})
ESPCtrl:Slider({Title = "render distance", Flag = "ESPRenderDist", Symbol = "m", Default = 1000, Min = 100, Max = 5000, Decimals = 1})
ESPCtrl:Toggle({Title = "show box", Flag = "ESPShowBox", Default = false, Callback = function(s)
    if espS then
        espS.boxMode = s and (Library.Flags["ESPBoxMode"] or "Corner") or "None"
    end
end})

ESPColors = MainTab:Section("esp colors", "Right")
ESPColors:Toggle({Title = "box color", Flag = "ESPBoxColorTog", Default = false}):Colorpicker({Color = Color3.fromRGB(255, 155, 205), Flag = "ESPBoxColor"})
ESPColors:Toggle({Title = "name color", Flag = "ESPNameColorTog", Default = false}):Colorpicker({Color = Color3.fromRGB(255, 155, 205), Flag = "ESPNameColor"})
ESPColors:Toggle({Title = "skeleton color", Flag = "ESPSkelColorTog", Default = false}):Colorpicker({Color = Color3.fromRGB(255, 155, 205), Flag = "ESPSkelColor"})
ESPColors:Toggle({Title = "tracer color", Flag = "ESPTracColorTog", Default = false}):Colorpicker({Color = Color3.fromRGB(255, 155, 205), Flag = "ESPTracColor"})
ESPColors:Slider({Title = "font size", Flag = "ESPFontSize", Symbol = "px", Default = 13, Min = 8, Max = 20, Decimals = 1})

local ESPBox = MainTab:Section("box", "Right")
ESPBox:Dropdown({Title = "box mode", Flag = "ESPBoxMode", List = {"Corner","2D","3D","None"}, Default = "Corner", Callback = function(v)
    if espS and Library.Flags["ESPShowBox"] then espS.boxMode = v end
end})
ESPBox:Slider({Title = "box thickness", Flag = "ESPBoxThick", Symbol = "", Default = 3, Min = 1, Max = 10, Decimals = 1})

ESPHealth = MainTab:Section("health bar", "Right")
ESPHealth:Dropdown({Title = "position", Flag = "ESPHealthPos", List = {"Left","Right","Top","Bottom"}, Default = "Left"})
ESPHealth:Dropdown({Title = "gradient", Flag = "ESPHealthGrad", List = {"GreenRed","RedGreen","StaticGreen","StaticRed"}, Default = "GreenRed"})
ESPHealth:Slider({Title = "bar width", Flag = "ESPHealthWidth", Symbol = "px", Default = 4, Min = 2, Max = 10, Decimals = 1})

ESPSkeleton = MainTab:Section("skeleton", "Left")
ESPSkeleton:Toggle({Title = "show skeleton", Flag = "ESPSkeleton", Default = false})
ESPSkeleton:Slider({Title = "line thickness", Flag = "ESPSkelThick", Symbol = "", Default = 2, Min = 1, Max = 10, Decimals = 1})

ESPTracers = MainTab:Section("tracers", "Left")
local _togESPTracers = ESPTracers:Toggle({Title = "show tracers", Flag = "ESPTracers", Default = false})
_togESPTracers:Keybind({Title = "tracers key", Flag = "ESPTracersKey", Key = Enum.KeyCode.End, StateType = "Always", Callback = function() end})
ESPTracers:Dropdown({Title = "origin", Flag = "ESPTracOrigin", List = {"Bottom","Center","Top","Mouse"}, Default = "Bottom"})
ESPTracers:Slider({Title = "thickness", Flag = "ESPTracThick", Symbol = "", Default = 2, Min = 1, Max = 10, Decimals = 1})
ESPTracers:Slider({Title = "transparency", Flag = "ESPTracTransp", Symbol = "", Default = 3, Min = 0, Max = 10, Decimals = 1})

ESPChams = MainTab:Section("chams", "Left")
local _togESPChams = ESPChams:Toggle({Title = "enable chams", Flag = "ESPChams", Default = false})
_togESPChams:Keybind({Title = "chams key", Flag = "ESPChamsKey", Key = Enum.KeyCode.Home, StateType = "Always", Callback = function() end})
ESPChams:Slider({Title = "transparency", Flag = "ESPChamsTransp", Symbol = "", Default = 5, Min = 0, Max = 10, Decimals = 1})
ESPChams:Toggle({Title = "chams fill", Flag = "ESPChamsFillTog", Default = false}):Colorpicker({Color = Color3.fromRGB(170, 90, 255), Flag = "ESPChamsFill"})
ESPChams:Toggle({Title = "chams outline", Flag = "ESPChamsOutTog", Default = false}):Colorpicker({Color = Color3.fromRGB(255, 155, 205), Flag = "ESPChamsOut"})

ESPHitMark = MainTab:Section("hit marker", "Right")
ESPHitMark:Toggle({Title = "hit marker", Flag = "HitMarker", Default = false})
ESPHitMark:Slider({Title = "fade time", Flag = "HitMarkerFade", Symbol = "s", Default = 4, Min = 1, Max = 20, Decimals = 1})
ESPHitMark:Toggle({Title = "marker color", Flag = "HitMarkerColTog", Default = false}):Colorpicker({Color = Color3.fromRGB(255, 255, 255), Flag = "HitMarkerCol"})


_G.EH_MainTab   = MainTab
