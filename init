-- save original zoom distances before third person ever touches them
local _tpOrigMaxZoom = nil
local _tpOrigMinZoom = nil

local _tpFreeMouseConn = nil

local function applyThirdPerson(enabled)
    -- clean up free-mouse connection when toggling anything
    if _tpFreeMouseConn then _tpFreeMouseConn:Disconnect(); _tpFreeMouseConn = nil end

    if enabled then
        -- save originals once
        if _tpOrigMaxZoom == nil then
            _tpOrigMaxZoom = pcall(function() return player.CameraMaxZoomDistance end) and player.CameraMaxZoomDistance or 0.5
            _tpOrigMinZoom = pcall(function() return player.CameraMinZoomDistance end) and player.CameraMinZoomDistance or 0.5
        end

        player.CameraMode = Enum.CameraMode.Classic
        pcall(function()
            player.CameraMaxZoomDistance = BrzS.thirdPersonDist
            player.CameraMinZoomDistance = 0.5
        end)

        if BrzS.thirdPersonMode == "free" then
            -- free mode: camera orbits freely, character does NOT rotate with mouse
            -- Use Follow so the camera stays behind but mouse controls camera independently
            pcall(function()
                player.DevComputerCameraMode = Enum.DevComputerCameraMovementMode.Follow
            end)
            -- Unlock mouse from character rotation so you can look around without moving
            pcall(function()
                UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            end)
            -- Hold unlock each heartbeat since game may re-lock it
            _tpFreeMouseConn = RunService.Heartbeat:Connect(function()
                if BrzS.thirdPerson and BrzS.thirdPersonMode == "free" then
                    pcall(function()
                        if UserInputService.MouseBehavior ~= Enum.MouseBehavior.Default then
                            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
                        end
                    end)
                end
            end)
        else
            -- shift mode: classic over-shoulder, mouse locked to character
            pcall(function()
                player.DevComputerCameraMode = Enum.DevComputerCameraMovementMode.Classic
            end)
        end
    else
        -- force zoom to 0 to lock first person, then set mode
        pcall(function()
            player.CameraMaxZoomDistance = 0.5
            player.CameraMinZoomDistance = 0.5
        end)
        player.CameraMode = Enum.CameraMode.LockFirstPerson
        pcall(function()
            player.DevComputerCameraMode = Enum.DevComputerCameraMovementMode.Default
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        end)
        -- restore original zoom after a tick so the game accepts it
        task.delay(0.1, function()
            pcall(function()
                player.CameraMaxZoomDistance = _tpOrigMaxZoom or 0.5
                player.CameraMinZoomDistance = _tpOrigMinZoom or 0.5
            end)
            _tpOrigMaxZoom = nil
            _tpOrigMinZoom = nil
        end)
    end
end

local _tpTimer = 0
RunService.Heartbeat:Connect(function(dt)
    _tpTimer = _tpTimer + dt
