-- ─── Auto Death Farmer ────────────────────────────────────────────────────────
local _farmer = {
    running=false, walkSecs=50, _thread=nil, spawnX=nil, spawnY=nil, recording=false,
}
local FARMER_LOG = "ExchangeHook/farmer_log.txt"
local function _flog(msg)
    local line = "[" .. os.date("%H:%M:%S") .. "] [EH Farmer] " .. tostring(msg)
    print(line)
    pcall(function()
        if not writefile then return end
        if isfolder and not isfolder("ExchangeHook") then pcall(function() makefolder("ExchangeHook") end) end
        local existing = ""
        pcall(function() if isfile and isfile(FARMER_LOG) and readfile then existing = readfile(FARMER_LOG) end end)
        writefile(FARMER_LOG, existing .. line .. "\n")
    end)
end
local function _farmerSendKey(keyCode)
    pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendKeyEvent(true, keyCode, false, game); task.wait(0.08)
        VIM:SendKeyEvent(false,keyCode, false, game); task.wait(0.05)
    end)
end
local function _nukeClickBtn(btn)
    pcall(function()
        if typeof(getconnections)=="function" then
            for _, sig in ipairs({btn.MouseButton1Click,btn.Activated,btn.MouseButton1Down}) do
                for _, c in ipairs(getconnections(sig) or {}) do pcall(function() c:Fire() end) end
            end
        end
    end)
    pcall(function() if typeof(firesignal)=="function" then firesignal(btn.MouseButton1Click) end end)
    pcall(function() btn.MouseButton1Click:Fire() end); pcall(function() btn.Activated:Fire() end)
    pcall(function() btn.MouseButton1Down:Fire(0,0) end); task.wait(0.04)
    pcall(function() btn.MouseButton1Up:Fire(0,0) end)
    pcall(function()
        local cx = math.floor(btn.AbsolutePosition.X + btn.AbsoluteSize.X*0.5)
        local cy = math.floor(btn.AbsolutePosition.Y + btn.AbsoluteSize.Y*0.5)
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendMouseMoveEvent(cx,cy,game); task.wait(0.06)
        VIM:SendMouseButtonEvent(cx,cy,0,true,game,1); task.wait(0.06)
        VIM:SendMouseButtonEvent(cx,cy,0,false,game,1)
    end)
end
local function _farmerMouseClick(x, y)
    _flog("ClickAtPos " .. math.floor(x) .. "," .. math.floor(y))
    local pg = player:FindFirstChild("PlayerGui")
    if pg then
        local ok, objs = pcall(function() return pg:GetGuiObjectsAtPosition(x, y) end)
        if ok and objs and #objs > 0 then
            for _, obj in ipairs(objs) do
                if obj:IsA("TextButton") or obj:IsA("ImageButton") or obj:IsA("GuiButton") then
                    _nukeClickBtn(obj); break
                end
            end
        end
    end
    task.wait(0.05)
    pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendMouseMoveEvent(x,y,game); task.wait(0.08)
        VIM:SendMouseButtonEvent(x,y,0,true,game,1); task.wait(0.08)
        VIM:SendMouseButtonEvent(x,y,0,false,game,1)
    end)
end
local function _farmerFindAndClickButton(patterns)
    local pg = player:FindFirstChild("PlayerGui")
    if not pg then return false end
    for _, gui in ipairs(pg:GetDescendants()) do
        if (gui:IsA("TextButton") or gui:IsA("ImageButton") or gui:IsA("GuiButton")) and gui.Visible then
            local ok, t = pcall(function() return gui.Text end)
            local searchStr = (ok and t and t ~= "") and t or gui.Name
            local tl = searchStr:lower()
            for _, pat in ipairs(patterns) do
                if tl:find(pat, 1, true) then _nukeClickBtn(gui); return true end
            end
        end
    end
    return false
end
local function _farmerGiveUp()
    _flog("GiveUp")
    _farmerSendKey(Enum.KeyCode.Escape); task.wait(0.4)
    _farmerSendKey(Enum.KeyCode.R); task.wait(0.4)
    _farmerSendKey(Enum.KeyCode.Return); task.wait(0.3)
    _farmerFindAndClickButton({"give up","flee","extract","leave"})
end
local function _farmerWalkForward(secs)
    local t0 = os.clock()
    while os.clock()-t0 < secs and _farmer.running do
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 then hum:MoveTo(hrp.Position + hrp.CFrame.LookVector*500) end
        task.wait(0.1)
    end
end
local function _farmerLoop()
    while _farmer.running do
        _farmerWalkForward(_farmer.walkSecs)
        if not _farmer.running then break end
        _farmerGiveUp()
        task.wait(8)
        if not _farmer.running then break end
        if _farmer.spawnX and _farmer.spawnY then
            _farmerMouseClick(_farmer.spawnX, _farmer.spawnY); task.wait(0.5)
            _farmerMouseClick(_farmer.spawnX, _farmer.spawnY)
        else
            _farmerFindAndClickButton({"west","estonian","spawn on"})
        end
        task.wait(5)
    end
end
