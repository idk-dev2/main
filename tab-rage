-- ── Ballistic helpers (petal) ─────────────────────────────────────────────────
local function _saaSolve(A, B, C)
    local d = B*B - 4*A*C
    if d < 0 then return end
    local s = math.sqrt(d)
    return (-B - s)/(2*A), (-B + s)/(2*A)
end
local function _saaFlight(dir, grav, speed)
    local r1, r2 = _saaSolve(grav:Dot(grav)/4, grav:Dot(dir) - speed^2, dir:Dot(dir))
    if r1 and r2 then
        local t = math.min(r1, r2)
        if t > 0 then return math.sqrt(t) end
    end
    return 0
end
local function _saaPredict(part, origin, speed, drop)
    local g = Vector3.yAxis * (drop * 2)
    local t = _saaFlight(part.Position - origin, g, speed)
    return part.Position + part.Velocity * t
end
local function _saaDrop(origin, target, speed, drop)
    local g = Vector3.yAxis * (drop * 2)
    local t = _saaFlight(target - origin, g, speed)
    return 0.5 * g * t^2
end

-- ── Target finder ─────────────────────────────────────────────────────────────
-- Raycast from camera to a part, excluding player + that part's parent model.
-- Returns true if nothing blocks line of sight.
local _saVisParams = RaycastParams.new()
local function _saPartVisible(part)
    local origin = cam.CFrame.Position
    local dir    = part.Position - origin
    _saVisParams.FilterDescendantsInstances = {player.Character, part.Parent}
    _saVisParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(origin, dir, _saVisParams)
    return result == nil
end

local function _saGetTarget()
    local visOnly = Library.Flags["AimVisible"]
    local closest, bestDist = nil, _saFOV
    local center = cam.ViewportSize / 2
    local az = workspace:FindFirstChild("AiZones")
    if az then
        for _, zone in ipairs(az:GetChildren()) do
            for _, char in ipairs(zone:GetChildren()) do
                if char:IsA("Model") then
                    local part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                    local hum  = char:FindFirstChildOfClass("Humanoid")
                    if part and hum and hum.Health > 0 then
                        -- visible check: skip if behind a wall
                        if visOnly and not _saPartVisible(part) then continue end
                        local pos, onscreen = cam:WorldToViewportPoint(part.Position)
                        if onscreen then
                            local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                            if d < bestDist then bestDist = d; closest = part end
                        end
                    end
                end
            end
        end
    end
    for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
        if plr ~= player and plr.Character then
            local hum  = plr.Character:FindFirstChildOfClass("Humanoid")
            local part = plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
            if part and hum and hum.Health > 0 then
                if visOnly and not _saPartVisible(part) then continue end
                local pos, onscreen = cam:WorldToViewportPoint(part.Position)
                if onscreen then
                    local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if d < bestDist then bestDist = d; closest = part end
                end
            end
        end
    end
    return closest
end

-- ── Silent aim — exact working petal logic ────────────────────────────────────
local function _hookNormal()
    if _saHooked then return end
    if not hookfunction then
        EH_Notify("[SA] hookfunction unavailable", 5); return
    end
    local RS = game:GetService("ReplicatedStorage")
    local ok, BulletModule = pcall(require, RS.Modules.FPS.Bullet)
    if not ok or not BulletModule or not BulletModule.CreateBullet then
        EH_Notify("[SA] Bullet module unavailable", 5); return
    end

    local OldBullet
    OldBullet = hookfunction(BulletModule.CreateBullet, function(a, b, c, d, aim, e, ammo, t, recoil)
        if _saActive and not checkcaller() then
            local target = _saGetTarget()
            if target and aim and aim.Position then
                instantTarget = target
                local ammoObj = RS.AmmoTypes:FindFirstChild(ammo)
                if ammoObj then
                    ammoObj:SetAttribute("Drag", 0)
                    local speed = ammoObj:GetAttribute("MuzzleVelocity") or 300
                    local drop  = ammoObj:GetAttribute("ProjectileDrop") or 0
                    local pos   = _saPrediction
                        and _saaPredict(target, aim.Position, speed, drop)
                        or  target.Position
                    local vdrop = _saaDrop(aim.Position, pos, speed, drop)
                    return OldBullet(a, b, c, d,
                        { CFrame = CFrame.new(aim.Position, pos + vdrop) },
                        e, ammo, t, recoil)
                end
            else
                instantTarget = nil
            end
        else
            instantTarget = nil
        end
        return OldBullet(a, b, c, d, aim, e, ammo, t, recoil)
    end)

    _saOrigCB = OldBullet
    _saHooked = true
    EH_Notify("[SA] silent aim active", 3)
end

-- ── Instant hit — ported from skvjw9z reference ───────────────────────────────
local function _hookInstantHit()
    if _ihHooked then return end
    local RS = game:GetService("ReplicatedStorage")
    local mt    = getrawmetatable(game)
    local oldNC = mt and mt.__namecall
    if not oldNC then
        EH_Notify("[IH] __namecall unavailable", 5); _ihActive = false; return
    end

    local function newNC(self, ...)
        local method = getnamecallmethod()
        local args   = { ... }

        -- Hook 1: zero drop and drag
        if _ihActive and method == "GetAttribute" then
            local attr = args[1]
            if attr == "ProjectileDrop" or attr == "Drag" then return 0 end
        end

        -- Hook 2: workspace:Raycast → fake instant hit
        if method == "Raycast" and self == workspace then
            if _ihActive and instantTarget and instantTarget.Parent then
                local origin = args[1]
                if typeof(origin) == "Vector3" then
                    lastHitPart = instantTarget
                    return {
                        Instance = instantTarget,
                        Position = instantTarget.Position,
                        Normal   = (origin - instantTarget.Position).Unit,
                        Material = instantTarget:IsA("BasePart")
                            and instantTarget.Material or Enum.Material.SmoothPlastic,
                        Distance = (instantTarget.Position - origin).Magnitude,
                    }
                end
            end
        end

        -- Hook 3: FireProjectile:InvokeServer — capture bullet metadata
        if _ihActive and method == "InvokeServer"
            and typeof(self) == "Instance" and self.Name == "FireProjectile"
        then
            local bulletId = args[2]
            local shotTick = args[3]
            local aimObj   = args[1]
            if bulletId then
                task.spawn(function()
                    pcall(function()
                        local char     = player.Character
                        local holding  = char and char:FindFirstChild("Holding")
                        local weapon   = holding and holding.Value
                        local ammoName = weapon and weapon:GetAttribute("AmmoType")
                        local ammoObj  = ammoName and RS.AmmoTypes:FindFirstChild(ammoName)
                        if not ammoObj then
                            for _, a in pairs(RS.AmmoTypes:GetChildren()) do ammoObj = a; break end
                        end
                        local speed  = ammoObj and ammoObj:GetAttribute("MuzzleVelocity") or 500
                        local origin = Vector3.new()
                        pcall(function()
                            if typeof(aimObj) == "CFrame" then
                                origin = aimObj.Position
                            elseif typeof(aimObj) == "Instance" then
                                origin = aimObj.CFrame and aimObj.CFrame.Position or aimObj.Position
                            end
                        end)
                        bulletData[bulletId] = {
                            Origin = origin, Tick = shotTick or 0,
                            Drag = 0, ProjectileSpeed = speed,
                        }
                    end)
                end)
            end
            return oldNC(self, ...)
        end

        -- Hook 4: ProjectileInflict:FireServer — tick correction
        if _ihActive and method == "FireServer"
            and typeof(self) == "Instance" and self.Name == "ProjectileInflict"
        then
            if debug and debug.traceback then
                local ok2, tb = pcall(debug.traceback)
                if ok2 and tb and tb:find("CharacterController") then
                    return oldNC(self, ...)
                end
            end
            local part     = lastHitPart
            local bulletId = args[3]
            if part and part.Parent then
                local K = bulletId and bulletData[bulletId]
                if K and K.ProjectileSpeed and K.ProjectileSpeed > 0 then
                    local dist = (part.Position - K.Origin).Magnitude
                    local A    = dist / K.ProjectileSpeed
                    local hPos = part.Position + (part.Velocity * A)
                    local o    = (hPos - part.Position).Magnitude
                    local spd2 = K.ProjectileSpeed - K.Drag * K.ProjectileSpeed^2 * A^2
                    if spd2 and spd2 > 0 then A = A + (o / spd2) end
                    if A > 0 then K.Tick = K.Tick + A end
                    args[4] = K.Tick
                    bulletData[bulletId] = nil
                end
                args[1] = part
                return oldNC(self, unpack(args))
            end
            return oldNC(self, ...)
        end

        return oldNC(self, ...)
    end

    local wrappedNC = typeof(newcclosure) == "function" and newcclosure(newNC) or newNC
    local assignOk, assignErr = pcall(function()
        setreadonly(mt, false)
        mt.__namecall = wrappedNC
        setreadonly(mt, true)
    end)
    if not assignOk then
        pcall(function() setreadonly(mt, true) end)
        EH_Notify("[IH] hook failed: " .. tostring(assignErr), 5)
        _ihActive = false; return
    end
    _ihHooked = true
    EH_Notify("[IH] instant hit active", 3)
end

local function _unhookInstantHit()
    if not _ihHooked then return end
    _ihActive = false; _ihHooked = false
    lastHitPart = nil; instantTarget = nil; bulletData = {}
    EH_Notify("[IH] instant hit off", 2)
end

